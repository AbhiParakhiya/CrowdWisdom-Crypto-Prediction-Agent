# ─── Required ──────────────────────────────────────────────────────────────────
# OpenRouter API key (free tier works — use mistralai/mistral-7b-instruct:free)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Apify API token (free tier: 5 USD monthly credit, more than enough)
APIFY_API_TOKEN=apify_api_ssHfNeVC8A7aCVoghZwkbHga53FKVD3wd7LJ

# ─── Optional (read-only market data — no auth needed for public endpoints) ────
# Polymarket: no key required for read-only CLOB/Gamma API
# Kalshi: no key required for read-only market data API
# Set these only if you want to place actual trades (not required for this demo)
POLYMARKET_PRIVATE_KEY=
KALSHI_EMAIL=
KALSHI_PASSWORD=

# ─── Model settings ──────────────────────────────────────────────────────────
# OpenRouter model (free options: mistralai/mistral-7b-instruct:free,
#                                  microsoft/phi-3-mini-128k-instruct:free)
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Kronos HuggingFace model repo (NeoQuasar/Kronos-base or NeoQuasar/Kronos-small)
# Set to "mock" to use the lightweight fallback predictor (faster, no GPU needed)
KRONOS_MODEL=mock

# ─── Trading parameters ────────────────────────────────────────────────────────
# Fraction of Kelly to use (0.25 = quarter Kelly — conservative)
KELLY_FRACTION=0.25
# Minimum confidence to act on a signal (0-1)
MIN_CONFIDENCE=0.55
# Portfolio size in USD (for Kelly sizing display)
PORTFOLIO_USD=10000
